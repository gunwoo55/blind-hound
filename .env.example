# Cloudflare Worker runtime configuration names.
# Never commit real provider keys. Set secrets with:
#   printf '%s' "$OLLAMA_API_KEY" | npx wrangler secret put OLLAMA_API_KEY
OLLAMA_MODEL=deepseek-v4-flash:cloud
OLLAMA_BASE_URL=https://ollama.com/api/chat
OLLAMA_API_KEY=replace_with_cloudflare_secret_only
